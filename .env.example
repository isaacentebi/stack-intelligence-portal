# Frontend -> backend API base URL
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Legacy public gates used by current investor/deck surfaces
NEXT_PUBLIC_THEME_MODE=light
NEXT_PUBLIC_ACCESS_HASH=change-me
NEXT_PUBLIC_INVESTOR_ACCESS_HASH=change-me

# Operator-only server envs
# Required in production on Vercel
OPERATOR_ACCESS_HASH=change-me
OPERATOR_SESSION_SECRET=change-me

# Required only if engine bearer auth is enabled
ENGINE_OPERATOR_API_TOKEN=change-me
